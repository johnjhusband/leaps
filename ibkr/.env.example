# Copy to .env and fill in the PAPER account login. NEVER commit .env (it is gitignored).
# Paper username is your live username with a DU prefix (e.g. live U1234567 -> paper DU1234567).
# Enable/find it: Client Portal -> Settings -> Account Settings -> Paper Trading Account.
TWS_USERID=DU0000000
TWS_PASSWORD=your_paper_password
